  <property name="windowTitle">
   <string>RepairMaster - Ремонтная мастерская</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f0f0f0;
    }
    QTabWidget::pane {
        background-color: #ffffff;
        border: 1px solid #cccccc;
        border-radius: 5px;
    }
    QTabBar::tab {
        background-color: #e0e0e0;
        padding: 10px 20px;
        margin-right: 2px;
        border-top-left-radius: 5px;
        border-top-right-radius: 5px;
        font-weight: bold;
        color: #000000;
    }
    QTabBar::tab:selected {
        background-color: #3498db;
        color: #ffffff;
    }
    QTabBar::tab:hover:!selected {
        background-color: #bdc3c7;
    }
    QTableView {
        background-color: #ffffff;
        alternate-background-color: #f9f9f9;
        selection-background-color: #3498db;
        selection-color: #ffffff;
        gridline-color: #cccccc;
        font-size: 12px;
        color: #000000;
    }
    QTableView::item {
        padding: 5px;
        color: #000000;
    }
    QHeaderView::section {
        background-color: #34495e;
        color: #ffffff;
        padding: 8px;
        font-weight: bold;
        border: none;
    }

    /* ========== ОСНОВНОЙ СТИЛЬ КНОПОК ========== */
    QPushButton {
        background-color: #3498db;  /* Синий фон */
        color: white;               /* Белый текст */
        border: none;
        border-radius: 5px;
        padding: 8px 15px;
        font-size: 12px;
        font-weight: bold;
        min-width: 100px;
    }
    QPushButton:hover {
        background-color: #2980b9;
    }
    QPushButton:pressed {
        background-color: #1c638e;
    }

    /* Зеленые кнопки (Добавить, Обновить) */
    QPushButton#addOrderButton,
    QPushButton#refreshOrdersButton,
    QPushButton#addWorkTypeButton,
    QPushButton#addPerformerButton,
    QPushButton#addCustomerButton {
        background-color: #27ae60;
    }
    QPushButton#addOrderButton:hover,
    QPushButton#refreshOrdersButton:hover,
    QPushButton#addWorkTypeButton:hover,
    QPushButton#addPerformerButton:hover,
    QPushButton#addCustomerButton:hover {
        background-color: #229954;
    }

    /* Оранжевые кнопки (Поиск, Редактировать) */
    QPushButton#searchOrdersButton,
    QPushButton#editOrderButton,
    QPushButton#editWorkTypeButton,
    QPushButton#editPerformerButton,
    QPushButton#editCustomerButton {
        background-color: #f39c12;
    }
    QPushButton#searchOrdersButton:hover,
    QPushButton#editOrderButton:hover,
    QPushButton#editWorkTypeButton:hover,
    QPushButton#editPerformerButton:hover,
    QPushButton#editCustomerButton:hover {
        background-color: #e67e22;
    }

    /* Красные кнопки (Удалить) */
    QPushButton#deleteOrderButton,
    QPushButton#deleteWorkTypeButton,
    QPushButton#deletePerformerButton,
    QPushButton#deleteCustomerButton {
        background-color: #e74c3c;
    }
    QPushButton#deleteOrderButton:hover,
    QPushButton#deleteWorkTypeButton:hover,
    QPushButton#deletePerformerButton:hover,
    QPushButton#deleteCustomerButton:hover {
        background-color: #c0392b;
    }

    /* Серая кнопка (Выход) */
    QPushButton#logoutButton {
        background-color: #7f8c8d;
        font-size: 13px;
        padding: 10px 25px;
    }
    QPushButton#logoutButton:hover {
        background-color: #6c7a7a;
    }

    QLineEdit, QComboBox, QDateEdit, QDoubleSpinBox, QTextEdit {
        background-color: #ffffff;
        border: 1px solid #cccccc;
        border-radius: 4px;
        padding: 6px;
        font-size: 12px;
        min-height: 25px;
        color: #000000;
    }
    QLineEdit:focus, QComboBox:focus, QDateEdit:focus {
        border: 1px solid #3498db;
    }
    QLabel {
        font-size: 12px;
        font-weight: bold;
        color: #000000;
    }
    QStatusBar {
        background-color: #34495e;
        color: #ffffff;
    }
   </string>
